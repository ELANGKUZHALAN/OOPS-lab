class Calculator {

    // Public method to add two integers
    public int add(int a, int b) {
        int result = a + b;
        System.out.println("Sum of two integers: " + result);
        return result;
    }

    // Protected method to add three integers
    protected int add(int a, int b, int c) {
        int result = a + b + c;
        System.out.println("Sum of three integers: " + result);
        return result;
    }

    // Private method to add two decimal numbers
    private double add(double a, double b) {
        double result = a + b;
        return result;
    }

    // Public method to access private method
    public void displayDecimalSum(double a, double b) {
        double result = add(a, b); // calling private method
        System.out.println("Sum of two decimal numbers: " + result);
    }
}

// Main class
public class Main {
    public static void main(String[] args) {

        Calculator calc = new Calculator();

        // Calling public method (2 integers)
        calc.add(10, 20);

        // Calling protected method (3 integers)
        calc.add(5, 10, 15);

        // Calling public method that uses private method internally
        calc.displayDecimalSum(2.5, 3.7);
    }
}